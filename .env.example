# =================================================================
# TechCorp Customer Success Digital FTE — Environment Variables
# =================================================================
# Copy this file to .env and fill in your values
# DEMO MODE works with only ANTHROPIC_API_KEY + DATABASE_URL

# -----------------------------------------------------------------
# MODE SETTINGS
# -----------------------------------------------------------------
DRY_RUN=true                      # true = DEMO mode, false = LIVE mode
LOG_LEVEL=INFO
BANK_CURRENCY=PKR
MAX_ACTIONS_PER_HOUR=10

# -----------------------------------------------------------------
# DATABASE (required in both modes)
# -----------------------------------------------------------------
DATABASE_URL=postgresql://fte_user:password@localhost:5432/fte_db
POSTGRES_USER=fte_user
POSTGRES_PASSWORD=password
POSTGRES_DB=fte_db

# -----------------------------------------------------------------
# KAFKA (not needed in demo mode — uses in-memory queue)
# -----------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=fte-consumer-group

# -----------------------------------------------------------------
# ANTHROPIC (required for AI agent)
# -----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------
# GMAIL (only needed in live mode DRY_RUN=false)
# -----------------------------------------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://localhost:8000/oauth/gmail/callback

# -----------------------------------------------------------------
# TWILIO WHATSAPP (only needed in live mode DRY_RUN=false)
# -----------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# -----------------------------------------------------------------
# NEXT.JS FRONTEND
# -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=TechCorp AI Support
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
